<Window x:Class="VodafoneNumberChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:converters="clr-namespace:VodafoneNumberChecker.Converters"
        Title="Vodafone Login" Height="1000" Width="1900"
        MinHeight="600" MinWidth="1200"
        MaxHeight="1080" MaxWidth="1920"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        SizeToContent="Manual"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:RowColorConverter x:Key="RowColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ColumnWidthConverter x:Key="ColumnWidthConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <!-- Modern Button Styles -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#ADB5BD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E9ECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E9ECEF"/>
                    <Setter Property="Foreground" Value="#ADB5BD"/>
                    <Setter Property="BorderBrush" Value="#DEE2E6"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0056B3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056B3"/>
                    <Setter Property="BorderBrush" Value="#004085"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004085"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B0BEC5"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#90A4AE"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#6C757D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A6268"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A6268"/>
                    <Setter Property="BorderBrush" Value="#545B62"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#545B62"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B0BEC5"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#90A4AE"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Stat Badge Style -->
        <Style x:Key="StatBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#20000000" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Current Number Badge Style -->
        <Style x:Key="CurrentNumberBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#007BFF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#40007BFF" Direction="270" ShadowDepth="3" BlurRadius="6" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Separator Style -->
        <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#DEE2E6"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Width" Value="1"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- WebView -->
            <RowDefinition Height="Auto" />
            <!-- settings -->
            <RowDefinition Height="Auto" />
            <!-- status -->
        </Grid.RowDefinitions>

        <!-- TabControl for WebView and Data -->
        <TabControl x:Name="tabControl" Grid.Row="0">
            <TabItem Header="WebView" x:Name="webViewTab">
                <wv2:WebView2 x:Name="webView"
                              NavigationCompleted="webView_NavigationCompleted"/>
            </TabItem>
            <TabItem Header="Phone Offers" x:Name="phoneOffersTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Filters -->
                    <Border Grid.Row="0" Background="#F0F0F0" Padding="12" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Фильтрация Group -->
                            <GroupBox Grid.Column="0" Header="Фильтрация" Margin="0,0,5,0" Padding="10">
                                <StackPanel>
                                    <TextBox Text="{Binding PhoneFilter, UpdateSourceTrigger=PropertyChanged}" 
                                             Margin="0,0,0,8"
                                             Padding="5">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Tag" Value="Поиск по номеру..."/>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <CheckBox Grid.Column="0" 
                                                  Content="Со скидкой" 
                                                  IsChecked="{Binding HasDiscount, TargetNullValue=False}"
                                                  Margin="0,0,5,0"/>
                                        
                                        <CheckBox Grid.Column="1" 
                                                  Content="С подарком" 
                                                  IsChecked="{Binding HasGift, TargetNullValue=False}"
                                                  Margin="5,0,5,0"/>
                                        
                                        <CheckBox Grid.Column="2" 
                                                  Content="С ошибками" 
                                                  IsChecked="{Binding HasError, TargetNullValue=False}"
                                                  Margin="5,0,5,0"/>
                                        
                                        <CheckBox Grid.Column="3" 
                                                  Content="Нет предложений" 
                                                  IsChecked="{Binding IsPropositionsNotFound, TargetNullValue=False}"
                                                  Margin="5,0,5,0"/>
                                        
                                        <CheckBox Grid.Column="4" 
                                                  Content="Нет подходящих" 
                                                  IsChecked="{Binding IsPropositionsNotSuitable, TargetNullValue=False}"
                                                  Margin="5,0,5,0"/>
                                        
                                        <Button Grid.Column="6" 
                                                Content="Применить" 
                                                Command="{Binding ApplyFilterCommand}"
                                                Margin="5,0,5,0" Padding="10,5"/>
                                        
                                        <Button Grid.Column="7" 
                                                Content="Очистить" 
                                                Command="{Binding ClearFilterCommand}"
                                                Margin="5,0" Padding="10,5"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                            
                            <!-- Параметры отображения Group -->
                            <GroupBox Grid.Column="1" Header="Параметры отображения" Margin="5,0" Padding="10">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="Реальное время" 
                                              IsChecked="{Binding IsRealtime}"
                                              Margin="0,0,10,0"/>
                                    
                                    <CheckBox Content="Использовать цвета" 
                                              IsChecked="{Binding UseColors}"
                                              Margin="0,0,10,0"/>
                                    
                                    <CheckBox Content="Все поля" 
                                              IsChecked="{Binding ShowAllFields}"/>
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                    </Border>
                    
                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding PhoneOffers}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              Margin="5"
                              FontSize="12"
                              RowHeight="26"
                              x:Name="phoneOffersDataGrid"
                              Loaded="PhoneOffersDataGrid_Loaded">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Номер телефона" Binding="{Binding PhoneNumber}" Width="150"/>
                            <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent}" Width="80" CanUserSort="True" SortMemberPath="DiscountPercent"/>
                            <DataGridTextColumn Header="Мин. пополнение" Binding="{Binding MinTopupAmount, StringFormat='{}{0:F2} грн'}" Width="120" CanUserSort="True" SortMemberPath="MinTopupAmount"/>
                            <DataGridTextColumn Header="Подарок" Binding="{Binding GiftAmount, StringFormat='{}{0:F2} грн'}" Width="100" CanUserSort="True" SortMemberPath="GiftAmount"/>
                            <DataGridTextColumn Header="Дней действия" Binding="{Binding ActiveDays}" Width="100" CanUserSort="True" SortMemberPath="ActiveDays"/>
                            <DataGridTextColumn Header="Действует до" Binding="{Binding ValidUntil, StringFormat='{}{0:yyyy-MM-dd}'}" Width="120" CanUserSort="True" SortMemberPath="ValidUntil"/>
                            <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                            <DataGridTextColumn Header="Итераций" Binding="{Binding IterationCount}" Width="70" CanUserSort="True" SortMemberPath="IterationCount"/>
                            <DataGridTemplateColumn Header="Обновлено" Width="140" x:Name="colUpdatedAt">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="IsProcessed" Width="100" x:Name="colIsProcessed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsProcessed}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ошибка" Binding="{Binding IsError}" Width="60"/>
                            <DataGridTextColumn Header="Описание ошибки" Binding="{Binding ErrorDescription}" Width="200"/>
                            <DataGridTextColumn Header="Нет предложений" Binding="{Binding IsPropositionsNotFound}" Width="150" x:Name="colIsPropositionsNotFound"/>
                            <DataGridTextColumn Header="Нет подходящих" Binding="{Binding IsPropositionsNotSuitable}" Width="150" x:Name="colIsPropositionsNotSuitable"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource RowColorConverter}">
                                            <Binding Path="."/>
                                            <Binding Path="DataContext.UseColors" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                    
                    <!-- Pagination -->
                    <Border Grid.Row="2" Background="#F0F0F0" Padding="12" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding PageInfo}" 
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="&lt;&lt;" 
                                        Command="{Binding FirstPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="&lt;" 
                                        Command="{Binding PreviousPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="&gt;" 
                                        Command="{Binding NextPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="&gt;&gt;" 
                                        Command="{Binding LastPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="Обновить" 
                                        Command="{Binding LoadDataCommand}" 
                                        Margin="2" Padding="10,5"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Proposition Types" x:Name="propositionTypesTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Filters -->
                    <Border Grid.Row="0" Background="#F0F0F0" Padding="12" Margin="5">
                        <StackPanel>
                            <CheckBox Content="Реальное время" 
                                      IsChecked="{Binding IsRealtime}"
                                      Margin="0,0,10,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding PropositionTypes}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              Margin="5"
                              FontSize="12"
                              x:Name="propositionTypesDataGrid"
                              Loaded="PropositionTypesDataGrid_Loaded">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTemplateColumn Header="Title" MinWidth="200" CanUserResize="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" 
                                                   TextWrapping="NoWrap"
                                                   Padding="5,2"
                                                   VerticalAlignment="Center">
                                            <TextBlock.ToolTip>
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxWidth="500"/>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80" CanUserSort="True" SortMemberPath="Count"/>
                            <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                            <DataGridTextColumn Header="Updated At" Binding="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                            <DataGridTemplateColumn Header="Content" Width="*" MinWidth="300">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <TextBlock Text="{Binding Content}" 
                                                       TextWrapping="Wrap"
                                                       Padding="5,2">
                                                <TextBlock.ToolTip>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" MaxWidth="500"/>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </ScrollViewer>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="MinHeight" Value="30"/>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                    
                    <!-- Pagination -->
                    <Border Grid.Row="2" Background="#F0F0F0" Padding="12" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding PropositionTypes.Count, StringFormat='Всего: {0}'}" 
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Обновить" 
                                        Command="{Binding LoadDataCommand}" 
                                        Margin="2" Padding="10,5"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Progress Bars -->
        <Grid Grid.Row="1" Background="#EEE">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Ввод номера -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="12,8">
                <TextBlock Text="Ввод номера" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                <ProgressBar Minimum="0" Maximum="100" Height="10" Margin="0,6,0,0" Value="{Binding ProgressInput}"/>
            </StackPanel>

            <!-- Нажатие на поиск -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,8">
                <TextBlock Text="Нажатие на поиск" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                <ProgressBar Minimum="0" Maximum="100" Height="10" Margin="0,6,0,0" Value="{Binding ProgressSearch}"/>
            </StackPanel>

            <!-- Следующий номер -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,8">
                <TextBlock Text="Следующий номер" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                <ProgressBar Minimum="0" Maximum="100" Height="10" Margin="0,6,0,0" Value="{Binding ProgressNext}"/>
            </StackPanel>
        </Grid>
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Action Buttons -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="18,12">
                    <!-- Authentication Status Message -->
                    <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="4" 
                            Padding="10,8" Margin="0,0,0,10" 
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Требуется авторизация. Пожалуйста, войдите в систему в WebView." 
                                     FontSize="13" FontWeight="SemiBold" Foreground="#856404" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Импорт номеров" 
                                Command="{Binding ImportPhoneNumbersCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Margin="0,0,8,0"/>
                        
                        <Button Content="{Binding ScanButtonText}" 
                                Command="{Binding StartStopScanCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,0"/>
                        
                        <Button Content="⚙ Config" 
                                Command="{Binding OpenConfigCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Margin="0,0,8,0"/>
                        
                        <Button x:Name="toggleWebViewButton" 
                                Content="👁 Скрыть WebView" 
                                Click="ToggleWebViewButton_Click"
                                Style="{StaticResource ModernButtonStyle}"
                                Margin="0,0,8,0"/>
                        
                        <Separator Style="{StaticResource ModernSeparatorStyle}" Margin="8,0"/>
                        
                        <Button Content="Сбросить все" 
                                Command="{Binding ResetAllCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Center: Statistics -->
                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="12">
                    <!-- Iteration Info -->
                    <Border Style="{StaticResource StatBadgeStyle}" Margin="6,0,6,6" 
                            Visibility="{Binding IterationInfo, Converter={StaticResource StringToVisibilityConverter}}"
                            Background="#E3F2FD" BorderBrush="#2196F3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding IterationInfo}" 
                                     FontSize="13"
                                     FontWeight="Bold" VerticalAlignment="Center" Foreground="#1976D2"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Statistics Row -->
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource StatBadgeStyle}" Margin="6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalNumbers, StringFormat='Всего: {0}'}" 
                                         FontSize="13"
                                         FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource StatBadgeStyle}" Margin="6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#28A745"/>
                                <TextBlock Text="{Binding ProcessedCount, StringFormat='Обработано: {0}'}" 
                                         FontSize="13"
                                         FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource StatBadgeStyle}" Margin="6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎁" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#17A2B8"/>
                                <TextBlock Text="{Binding OffersFoundCount, StringFormat='Найдено: {0}'}" 
                                         FontSize="13"
                                         FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource StatBadgeStyle}" Margin="6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#DC3545"/>
                                <TextBlock Text="{Binding ServerErrors, StringFormat='Ошибки: {0}'}" 
                                         FontSize="13"
                                         FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
                
                <!-- Right: Current Number -->
                <Border Grid.Column="2" Style="{StaticResource CurrentNumberBadgeStyle}" Margin="18,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📱" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Текущий номер" FontSize="12" Opacity="0.7" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding CurrentNumber}" 
                                     FontSize="15" FontWeight="Bold" Foreground="#007BFF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>