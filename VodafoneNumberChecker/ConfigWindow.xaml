<Window x:Class="VodafoneNumberChecker.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="520" Width="800"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="TopUpRuleColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, Path=Content}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Тайминги">
                <Grid Margin="8,12,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding TimingValidationMessage}"
                               Foreground="#C0392B"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="8,0,8,8"
                               Visibility="{Binding HasTimingValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Ввод номера -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="8,0">
                            <TextBlock Text="Ввод номера (сек)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Мин" HorizontalAlignment="Center" FontSize="11"/>
                            <Slider Minimum="0" Maximum="60" Value="{Binding DelayInputMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20"/>
                            <TextBlock Text="{Binding DelayInputMin, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Text="Макс" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="11"/>
                            <Slider Minimum="0" Maximum="60" Value="{Binding DelayInputMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20"/>
                            <TextBlock Text="{Binding DelayInputMax, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                        </StackPanel>

                        <!-- Нажатие на поиск -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0">
                            <TextBlock Text="Нажатие на поиск (сек)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Мин" HorizontalAlignment="Center" FontSize="11"/>
                            <Slider Minimum="0" Maximum="60" Value="{Binding DelaySearchMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20"/>
                            <TextBlock Text="{Binding DelaySearchMin, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Text="Макс" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="11"/>
                            <Slider Minimum="0" Maximum="60" Value="{Binding DelaySearchMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20"/>
                            <TextBlock Text="{Binding DelaySearchMax, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                        </StackPanel>

                        <!-- Следующий номер -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="8,0">
                            <TextBlock Text="Следующий номер (сек)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Мин" HorizontalAlignment="Center" FontSize="11"/>
                            <Slider Minimum="0" Maximum="60" Value="{Binding DelayNextMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20"/>
                            <TextBlock Text="{Binding DelayNextMin, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                            <TextBlock Text="Макс" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="11"/>
                            <Slider Minimum="0" Maximum="60" Value="{Binding DelayNextMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="20"/>
                            <TextBlock Text="{Binding DelayNextMax, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <!-- First pass time estimate -->
                    <Border Grid.Row="2" Margin="8,14,8,0" Padding="10" Background="#F5F8FF" BorderBrush="#D8E6FF" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Оценка времени первого прохода" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Text="{Binding PhoneNumbersCount, StringFormat='Номеров в базе: {0}'}" Margin="0,4,0,0" FontSize="11"/>
                            <TextBlock Text="{Binding EstimatedAverageFirstPassDuration, StringFormat='Приблизительно: {0}'}" Margin="0,4,0,0" FontSize="11"/>
                            <TextBlock Text="{Binding EstimatedMaxFirstPassDuration, StringFormat='Максимум: {0}'}" Margin="0,2,0,0" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Повторы">
                <Grid Margin="8,12,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Empty Propositions Repeats -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="8,0"
                                IsEnabled="{Binding AreIterationSlidersEnabled}">
                        <TextBlock Text="Количество циклов" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                        <Slider Minimum="0" Maximum="10" Value="{Binding EmptyPropositionsRepeats, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Height="20"/>
                        <TextBlock Text="{Binding EmptyPropositionsRepeats, StringFormat='{}{0}'}" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="11"/>
                        <TextBlock Text="Повторы для пустых предложений" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,3" FontSize="12"/>
                        <TextBlock Text="Для номеров где предложений не найдено" HorizontalAlignment="Center" FontSize="10" Opacity="0.7" Margin="0,0,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Error Numbers Repeats -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0"
                                IsEnabled="{Binding AreIterationSlidersEnabled}">
                        <TextBlock Text="Количество циклов" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                        <Slider Minimum="0" Maximum="10" Value="{Binding ErrorNumbersRepeats, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Height="20"/>
                        <TextBlock Text="{Binding ErrorNumbersRepeats, StringFormat='{}{0}'}" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="11"/>
                        <TextBlock Text="Повторы для номеров с ошибками" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,3" FontSize="12"/>
                        <TextBlock Text="Для номеров с ошибками" HorizontalAlignment="Center" FontSize="10" Opacity="0.7" Margin="0,0,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Дополнительные">
                <Grid Margin="8,12,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0"
                              Content="Пополнять номера"
                              IsChecked="{Binding ShouldTopUpNumbers, Mode=TwoWay}"
                              IsEnabled="{Binding IsTopUpOptionEnabled}"
                              Margin="0,0,0,12"/>
                    <CheckBox Grid.Row="1"
                              Content="Работать 24/7"
                              IsChecked="{Binding Is24x7Mode, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <GroupBox Grid.Row="2"
                              Header="Правила добавления в базу пополнений"
                              Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding TopUpRulesValidationMessage}"
                                       Foreground="#C0392B"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding HasTopUpRulesValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding TopUpRules}"
                                      SelectedItem="{Binding SelectedTopUpRule, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      MinHeight="120"
                                      HorizontalAlignment="Stretch"
                                      HorizontalScrollBarVisibility="Auto"
                                      CellEditEnding="TopUpRulesDataGrid_CellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Скидка % — от"
                                                        Binding="{Binding DiscountPercentFrom, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"
                                                        MinWidth="105"
                                                        HeaderStyle="{StaticResource TopUpRuleColumnHeaderStyle}"/>
                                    <DataGridTextColumn Header="Скидка % — до"
                                                        Binding="{Binding DiscountPercentTo, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"
                                                        MinWidth="105"
                                                        HeaderStyle="{StaticResource TopUpRuleColumnHeaderStyle}"/>
                                    <DataGridTextColumn Header="Мин. пополнение — от"
                                                        Binding="{Binding MinTopupAmountFrom, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F2}'}"
                                                        Width="*"
                                                        MinWidth="125"
                                                        HeaderStyle="{StaticResource TopUpRuleColumnHeaderStyle}"/>
                                    <DataGridTextColumn Header="Мин. пополнение — до"
                                                        Binding="{Binding MinTopupAmountTo, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F2}'}"
                                                        Width="*"
                                                        MinWidth="125"
                                                        HeaderStyle="{StaticResource TopUpRuleColumnHeaderStyle}"/>
                                    <DataGridTextColumn Header="Подарок — от"
                                                        Binding="{Binding GiftAmountFrom, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F2}'}"
                                                        Width="*"
                                                        MinWidth="105"
                                                        HeaderStyle="{StaticResource TopUpRuleColumnHeaderStyle}"/>
                                    <DataGridTextColumn Header="Подарок — до"
                                                        Binding="{Binding GiftAmountTo, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F2}'}"
                                                        Width="*"
                                                        MinWidth="105"
                                                        HeaderStyle="{StaticResource TopUpRuleColumnHeaderStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0">
                                <Button Content="Добавить"
                                        Command="{Binding AddTopUpRuleCommand}"
                                        Width="100"
                                        Height="28"
                                        Margin="0,0,8,0"/>
                                <Button Content="Удалить"
                                        Command="{Binding RemoveTopUpRuleCommand}"
                                        Width="100"
                                        Height="28"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="100" Height="30" Margin="5,0" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="100" Height="30" Margin="5,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
