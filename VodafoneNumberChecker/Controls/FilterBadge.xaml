<UserControl x:Class="VodafoneNumberChecker.Controls.FilterBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="150">
    <Border x:Name="mainBorder"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10,8"
            Cursor="Hand"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <CheckBox Grid.Column="0"
                      x:Name="checkBox"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Checked="CheckBox_Checked"
                      Unchecked="CheckBox_Unchecked"/>
            
            <TextBlock Grid.Column="1"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{Binding TextColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Margin="0,0,8,0"/>
            
            <Border Grid.Column="2"
                    Background="{Binding CountBackgroundColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    BorderBrush="{Binding CountBorderColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6,2"
                    MinWidth="30"
                    HorizontalAlignment="Right">
                <TextBlock Text="{Binding Count, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='{}{0}'}"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{Binding CountTextColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
