<Window x:Class="VodafoneLogin.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="350" Width="650"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Settings -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Ввод номера -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="8,0">
                <TextBlock Text="Ввод номера (сек)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="Мин" HorizontalAlignment="Center" FontSize="11"/>
                <Slider Minimum="0" Maximum="60" Value="{Binding DelayInputMin, Mode=TwoWay}" Height="20"/>
                <TextBlock Text="{Binding DelayInputMin, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                <TextBlock Text="Макс" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="11"/>
                <Slider Minimum="0" Maximum="60" Value="{Binding DelayInputMax, Mode=TwoWay}" Height="20"/>
                <TextBlock Text="{Binding DelayInputMax, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
            </StackPanel>

            <!-- Нажатие на поиск -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0">
                <TextBlock Text="Нажатие на поиск (сек)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="Мин" HorizontalAlignment="Center" FontSize="11"/>
                <Slider Minimum="0" Maximum="60" Value="{Binding DelaySearchMin, Mode=TwoWay}" Height="20"/>
                <TextBlock Text="{Binding DelaySearchMin, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                <TextBlock Text="Макс" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="11"/>
                <Slider Minimum="0" Maximum="60" Value="{Binding DelaySearchMax, Mode=TwoWay}" Height="20"/>
                <TextBlock Text="{Binding DelaySearchMax, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
            </StackPanel>

            <!-- Следующий номер -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="8,0">
                <TextBlock Text="Следующий номер (сек)" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="Мин" HorizontalAlignment="Center" FontSize="11"/>
                <Slider Minimum="0" Maximum="60" Value="{Binding DelayNextMin, Mode=TwoWay}" Height="20"/>
                <TextBlock Text="{Binding DelayNextMin, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
                <TextBlock Text="Макс" HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="11"/>
                <Slider Minimum="0" Maximum="60" Value="{Binding DelayNextMax, Mode=TwoWay}" Height="20"/>
                <TextBlock Text="{Binding DelayNextMax, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center" FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Iteration Cycles -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Empty Propositions Repeats -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="8,0">
                <TextBlock Text="Количество циклов" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                <Slider Minimum="0" Maximum="10" Value="{Binding EmptyPropositionsRepeats, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Height="20"/>
                <TextBlock Text="{Binding EmptyPropositionsRepeats, StringFormat='{}{0}'}" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="11"/>
                <TextBlock Text="Повторы для пустых предложений" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,3" FontSize="12"/>
                <TextBlock Text="Для номеров без предложений" HorizontalAlignment="Center" FontSize="10" Opacity="0.7" Margin="0,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Error Numbers Repeats -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0">
                <TextBlock Text="Количество циклов" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                <Slider Minimum="0" Maximum="10" Value="{Binding ErrorNumbersRepeats, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Height="20"/>
                <TextBlock Text="{Binding ErrorNumbersRepeats, StringFormat='{}{0}'}" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="11"/>
                <TextBlock Text="Повторы для номеров с ошибками" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,3" FontSize="12"/>
                <TextBlock Text="Для номеров с ошибками" HorizontalAlignment="Center" FontSize="10" Opacity="0.7" Margin="0,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="100" Height="30" Margin="5,0" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="100" Height="30" Margin="5,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

