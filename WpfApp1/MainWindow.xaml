<Window x:Class="VodafoneLogin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:converters="clr-namespace:VodafoneLogin.Converters"
        Title="Vodafone Login" Height="800" Width="1000"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:RowColorConverter x:Key="RowColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ColumnWidthConverter x:Key="ColumnWidthConverter"/>
        
        <!-- Modern Button Styles -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#ADB5BD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E9ECEF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0056B3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056B3"/>
                    <Setter Property="BorderBrush" Value="#004085"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004085"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#6C757D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A6268"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A6268"/>
                    <Setter Property="BorderBrush" Value="#545B62"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#545B62"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Stat Badge Style -->
        <Style x:Key="StatBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#20000000" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Current Number Badge Style -->
        <Style x:Key="CurrentNumberBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#007BFF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#40007BFF" Direction="270" ShadowDepth="3" BlurRadius="6" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Separator Style -->
        <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#DEE2E6"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Width" Value="1"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- WebView -->
            <RowDefinition Height="Auto" />
            <!-- settings -->
            <RowDefinition Height="Auto" />
            <!-- status -->
        </Grid.RowDefinitions>

        <!-- TabControl for WebView and Data -->
        <TabControl x:Name="tabControl" Grid.Row="0">
            <TabItem Header="WebView">
                <wv2:WebView2 x:Name="webView"
                              NavigationCompleted="webView_NavigationCompleted"/>
            </TabItem>
            <TabItem Header="Phone Offers" x:Name="phoneOffersTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Filters -->
                    <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Фильтры" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBox Grid.Column="0" 
                                         Text="{Binding PhoneFilter, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,10,0"
                                         Padding="5">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Tag" Value="Поиск по номеру..."/>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <CheckBox Grid.Column="1" 
                                          Content="Со скидкой" 
                                          IsChecked="{Binding HasDiscount, TargetNullValue=False}"
                                          Margin="5,0"/>
                                
                                <CheckBox Grid.Column="2" 
                                          Content="С подарком" 
                                          IsChecked="{Binding HasGift, TargetNullValue=False}"
                                          Margin="5,0"/>
                                
                                <CheckBox Grid.Column="3" 
                                          Content="Realtime" 
                                          IsChecked="{Binding IsRealtime}"
                                          Margin="5,0"/>
                                
                                <CheckBox Grid.Column="4" 
                                          Content="Use colors" 
                                          IsChecked="{Binding UseColors}"
                                          Margin="5,0"/>
                                
                                <CheckBox Grid.Column="5" 
                                          Content="All fields" 
                                          IsChecked="{Binding ShowAllFields}"
                                          Margin="5,0"/>
                                
                                <Button Grid.Column="6" 
                                        Content="Применить" 
                                        Command="{Binding ApplyFilterCommand}"
                                        Margin="5,0" Padding="10,5"/>
                                
                                <Button Grid.Column="7" 
                                        Content="Очистить" 
                                        Command="{Binding ClearFilterCommand}"
                                        Margin="5,0" Padding="10,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding PhoneOffers}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              Margin="5"
                              x:Name="phoneOffersDataGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Номер телефона" Binding="{Binding PhoneNumber}" Width="150"/>
                            <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent}" Width="80" CanUserSort="True" SortMemberPath="DiscountPercent"/>
                            <DataGridTextColumn Header="Мин. пополнение" Binding="{Binding MinTopupAmount, StringFormat='{}{0:F2} грн'}" Width="120" CanUserSort="True" SortMemberPath="MinTopupAmount"/>
                            <DataGridTextColumn Header="Подарок" Binding="{Binding GiftAmount, StringFormat='{}{0:F2} грн'}" Width="100" CanUserSort="True" SortMemberPath="GiftAmount"/>
                            <DataGridTextColumn Header="Дней действия" Binding="{Binding ActiveDays}" Width="100" CanUserSort="True" SortMemberPath="ActiveDays"/>
                            <DataGridTextColumn Header="Действует до" Binding="{Binding ValidUntil, StringFormat='{}{0:yyyy-MM-dd}'}" Width="120" CanUserSort="True" SortMemberPath="ValidUntil"/>
                            <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                            <DataGridTemplateColumn Header="Обновлено" Width="140" x:Name="colUpdatedAt">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="IsSynchronized" Width="100" x:Name="colIsSynchronized">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsSynchronized}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="SyncedAt" Width="140" x:Name="colSyncedAt">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SyncedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="LastSyncAttempt" Width="140" x:Name="colLastSyncAttempt">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LastSyncAttempt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="SyncAttempts" Width="100" x:Name="colSyncAttempts">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SyncAttempts}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="SyncError" Width="200" x:Name="colSyncError">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SyncError}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="IsProcessed" Width="100" x:Name="colIsProcessed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsProcessed}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ошибка" Binding="{Binding IsError}" Width="60"/>
                            <DataGridTextColumn Header="Описание ошибки" Binding="{Binding ErrorDescription}" Width="200"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource RowColorConverter}">
                                            <Binding Path="."/>
                                            <Binding Path="DataContext.UseColors" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                    
                    <!-- Pagination -->
                    <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding PageInfo}" 
                                       VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="&lt;&lt;" 
                                        Command="{Binding FirstPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="&lt;" 
                                        Command="{Binding PreviousPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="&gt;" 
                                        Command="{Binding NextPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="&gt;&gt;" 
                                        Command="{Binding LastPageCommand}" 
                                        Margin="2" Padding="10,5"/>
                                <Button Content="Обновить" 
                                        Command="{Binding LoadDataCommand}" 
                                        Margin="2" Padding="10,5"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Progress Bars -->
        <Grid Grid.Row="1" Background="#EEE">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Ввод номера -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Ввод номера" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                <ProgressBar Minimum="0" Maximum="100" Height="8" Margin="0,5,0,0" Value="{Binding ProgressInput}"/>
            </StackPanel>

            <!-- Нажатие на поиск -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Нажатие на поиск" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                <ProgressBar Minimum="0" Maximum="100" Height="8" Margin="0,5,0,0" Value="{Binding ProgressSearch}"/>
            </StackPanel>

            <!-- Следующий номер -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Следующий номер" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                <ProgressBar Minimum="0" Maximum="100" Height="8" Margin="0,5,0,0" Value="{Binding ProgressNext}"/>
            </StackPanel>
        </Grid>
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Action Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,10">
                    <Button Content="Импорт номеров" 
                            Command="{Binding ImportPhoneNumbersCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="{Binding ScanButtonText}" 
                            Command="{Binding StartStopScanCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="⚙ Config" 
                            Command="{Binding OpenConfigCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="0,0,8,0"/>
                    
                    <Separator Style="{StaticResource ModernSeparatorStyle}" Margin="8,0"/>
                    
                    <Button Content="Сбросить обработанные" 
                            Command="{Binding ResetScannedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="Сбросить все" 
                            Command="{Binding ResetAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
                
                <!-- Center: Statistics -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                    <Border Style="{StaticResource StatBadgeStyle}" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalNumbers, StringFormat='Всего: {0}'}" 
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource StatBadgeStyle}" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#28A745"/>
                            <TextBlock Text="{Binding ProcessedCount, StringFormat='Обработано: {0}'}" 
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource StatBadgeStyle}" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎁" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#17A2B8"/>
                            <TextBlock Text="{Binding OffersFoundCount, StringFormat='Найдено: {0}'}" 
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource StatBadgeStyle}" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#DC3545"/>
                            <TextBlock Text="{Binding ServerErrors, StringFormat='Ошибки: {0}'}" 
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Right: Current Number -->
                <Border Grid.Column="2" Style="{StaticResource CurrentNumberBadgeStyle}" Margin="15,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📱" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Текущий номер" FontSize="11" Opacity="0.7" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding CurrentNumber}" 
                                     FontSize="14" FontWeight="Bold" Foreground="#007BFF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>