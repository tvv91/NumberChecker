<Window x:Class="VodafoneLogin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Vodafone Login" Height="800" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- WebView -->
            <RowDefinition Height="Auto" />
            <!-- settings -->
            <RowDefinition Height="Auto" />
            <!-- status -->
        </Grid.RowDefinitions>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="webView"
                      Grid.Row="0"
                      NavigationCompleted="webView_NavigationCompleted"/>

        <!-- Settings -->
        <Grid Grid.Row="1" Background="#EEE">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Ввод номера -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Ввод номера (сек)" HorizontalAlignment="Center"/>
                <TextBlock Text="Мин" HorizontalAlignment="Center"/>
                <Slider x:Name="DelayInputMin" Minimum="0" Maximum="60" Value="3"/>
                <TextBlock Text="{Binding ElementName=DelayInputMin, Path=Value, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center"/>
                <TextBlock Text="Макс" HorizontalAlignment="Center"/>
                <Slider x:Name="DelayInputMax" Minimum="0" Maximum="60" Value="5"/>
                <TextBlock Text="{Binding ElementName=DelayInputMax, Path=Value, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center"/>

                <!-- Прогресс бар -->
                <ProgressBar x:Name="ProgressInput" Minimum="0" Maximum="100" Height="15" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Нажатие на поиск -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Нажатие на поиск (сек)" HorizontalAlignment="Center"/>
                <TextBlock Text="Мин" HorizontalAlignment="Center"/>
                <Slider x:Name="DelaySearchMin" Minimum="0" Maximum="60" Value="3"/>
                <TextBlock Text="{Binding ElementName=DelaySearchMin, Path=Value, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center"/>
                <TextBlock Text="Макс" HorizontalAlignment="Center"/>
                <Slider x:Name="DelaySearchMax" Minimum="0" Maximum="60" Value="5"/>
                <TextBlock Text="{Binding ElementName=DelaySearchMax, Path=Value, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center"/>

                <!-- Прогресс бар -->
                <ProgressBar x:Name="ProgressSearch" Minimum="0" Maximum="100" Height="15" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Следующий номер -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Следующий номер (сек)" HorizontalAlignment="Center"/>
                <TextBlock Text="Мин" HorizontalAlignment="Center"/>
                <Slider x:Name="DelayNextMin" Minimum="0" Maximum="60" Value="3"/>
                <TextBlock Text="{Binding ElementName=DelayNextMin, Path=Value, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center"/>
                <TextBlock Text="Макс" HorizontalAlignment="Center"/>
                <Slider x:Name="DelayNextMax" Minimum="0" Maximum="60" Value="5"/>
                <TextBlock Text="{Binding ElementName=DelayNextMax, Path=Value, StringFormat='{}{0:F0} c'}" HorizontalAlignment="Center"/>

                <!-- Прогресс бар -->
                <ProgressBar x:Name="ProgressNext" Minimum="0" Maximum="100" Height="15" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        <!-- Status -->
        <StatusBar Grid.Row="2" VerticalAlignment="Bottom" FontSize="16">
            <StatusBarItem>
                <TextBlock x:Name="txtTotalNumbers" Text="Всего номеров: 0" />
            </StatusBarItem>

            <Separator Width="10"/>

            <StatusBarItem>
                <TextBlock x:Name="txtProcessed" Text="Обработано: 0" />
            </StatusBarItem>

            <Separator Width="10"/>

            <StatusBarItem>
                <TextBlock x:Name="txtCurrentNumber" Text="Текущий номер: -" />
            </StatusBarItem>

            <Separator Width="10"/>

            <StatusBarItem>
                <TextBlock x:Name="txtOffersFound" Text="Найдено предложений: 0" />
            </StatusBarItem>

            <Separator Width="10"/>

            <StatusBarItem>
                <TextBlock x:Name="txtServerErrors" Text="Ошибки: 0" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>